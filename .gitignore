# Backups created by install.sh
*.bak
*.bak.*

# Machine-specific Claude settings (permissions, MCP servers, secrets)
claude/settings.local.json
claude/.credentials.json

# Claude runtime state — never sync these
claude/projects/
claude/sessions/
claude/history.jsonl
claude/plugins/
claude/cache/
claude/file-history/
claude/paste-cache/
claude/session-env/
claude/backups/
claude/debug/

# Machine-specific Codex settings and runtime state
codex/config.toml
codex/auth.json
codex/sessions/
codex/cache/
codex/log/
codex/tmp/

# loop dependencies (bun.lock is committed; run install.sh to restore)
loop/node_modules/

# OS junk
.DS_Store
Thumbs.db

# Editor cruft
*.swp
*.swo
